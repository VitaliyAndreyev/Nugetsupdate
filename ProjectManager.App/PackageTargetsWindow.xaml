<Window x:Class="ProjectManager.App.PackageTargetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Solution package targets"
        Height="700"
        Width="980"
        MinHeight="420"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Package targets for the entire solution"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="Choose one version per package. The selection is applied to every project that references that package."
                       Foreground="#607086"
                       Margin="0,5,0,0" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#DCE3EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" MinWidth="130" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Grid.ColumnSpan="9"
                           Text="Group target assignment"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Match"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Row="2" Grid.Column="1"
                          ItemsSource="{Binding PackageGroupMatchModes}"
                          SelectedItem="{Binding PackageGroupMatchMode, UpdateSourceTrigger=PropertyChanged}"
                          Height="32" />
                <TextBlock Grid.Row="2" Grid.Column="3"
                           Text="Pattern"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Row="2" Grid.Column="4"
                         Text="{Binding PackageGroupPattern, UpdateSourceTrigger=PropertyChanged}"
                         Height="32"
                         VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="6"
                           Text="Target"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Grid.Row="2" Grid.Column="7"
                          ItemsSource="{Binding PackageGroupAvailableVersions}"
                          SelectedItem="{Binding PackageGroupTargetVersion, UpdateSourceTrigger=PropertyChanged}"
                          Height="32" />
                <Button Grid.Row="2" Grid.Column="8"
                        Content="Set group target"
                        Command="{Binding ApplyPackageGroupTargetCommand}"
                        Padding="14,7"
                        Margin="8,0,0,0" />
                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Grid.ColumnSpan="9"
                           Text="{Binding PackageGroupMatchSummary}"
                           Foreground="#607086" />
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#DCE3EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <DataGrid ItemsSource="{Binding SolutionPackageTargetsView}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Use"
                                            Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                            Width="56" />
                    <DataGridTextColumn Header="Package"
                                        Binding="{Binding PackageName}"
                                        IsReadOnly="True"
                                        Width="2*" />
                    <DataGridTemplateColumn Header="Projects" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ProjectCount}"
                                           ToolTip="{Binding ProjectNames}"
                                           HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Current"
                                        Binding="{Binding CurrentVersions}"
                                        IsReadOnly="True"
                                        Width="1.5*" />
                    <DataGridTemplateColumn Header="Target" Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding AvailableVersions}"
                                          SelectedItem="{Binding TargetVersion, UpdateSourceTrigger=PropertyChanged}"
                                          MinWidth="165" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="5" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Latest for all"
                        Command="{Binding SelectLatestPackageTargetsCommand}"
                        Padding="14,7"
                        Margin="0,0,8,0" />
                <Button Content="Clear selection"
                        Command="{Binding ClearPackageTargetsCommand}"
                        Padding="14,7" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Apply targets"
                        IsDefault="True"
                        Padding="18,7"
                        Margin="0,0,8,0"
                        Click="Apply_Click" />
                <Button Content="Close"
                        IsCancel="True"
                        Padding="18,7" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
