<Window x:Class="ProjectManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:ProjectManager.App.Models"
        mc:Ignorable="d"
        Title="Project Manager"
        Height="868"
        MinHeight="640"
        Width="1469"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="110" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type models:ProjectNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Border Width="18"
                        Height="18"
                        Margin="0,0,6,0"
                        CornerRadius="9"
                        ToolTip="{Binding WorkflowStatus}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Hidden" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkflowStatus}" Value="Working">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Background" Value="#2563EB" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStatus}" Value="Completed">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Background" Value="#15803D" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStatus}" Value="Failed">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Background" Value="#B91C1C" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding WorkflowStatus}" Value="Pending">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Background" Value="#64748B" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="Bold">
                        <TextBlock.RenderTransform>
                            <RotateTransform />
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WorkflowStatus}" Value="Working">
                                        <Setter Property="Text" Value="&#x21BB;" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="WorkingRotation">
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="0:0:0.8"
                                                                     RepeatBehavior="Forever" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="WorkingRotation" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding WorkflowStatus}" Value="Completed">
                                        <Setter Property="Text" Value="&#x2713;" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding WorkflowStatus}" Value="Failed">
                                        <Setter Property="Text" Value="&#x2715;" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding WorkflowStatus}" Value="Pending">
                                        <Setter Property="Text" Value="&#x2026;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="360" MinWidth="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#DCE3EC" BorderThickness="1" CornerRadius="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Open solution"
                        Command="{Binding BrowseSolutionCommand}" />
                <TextBox Grid.Column="1"
                         Text="{Binding SolutionPath, Mode=OneWay}"
                         IsReadOnly="True"
                         Height="34"
                         Margin="4,0,16,0"
                         VerticalContentAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="Current version"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="3"
                         Text="{Binding SolutionVersion, Mode=OneWay}"
                         IsReadOnly="True"
                         Height="34"
                         Margin="0,0,16,0"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="4"
                        Content="Settings"
                        Click="NuGetSources_Click"
                        Margin="0" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="White" BorderBrush="#DCE3EC" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,16,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" MinWidth="220" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" MinWidth="380" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#DCE3EC" BorderThickness="1" CornerRadius="8" Padding="14">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Solution projects"
                                       Style="{StaticResource PanelTitle}"
                                       Margin="0,0,0,12" />
                            <ListBox ItemsSource="{Binding ProjectTree}"
                                     SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Padding="0"
                                     HorizontalContentAlignment="Left"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                        </DockPanel>
                    </Border>

                    <GridSplitter Grid.Column="1"
                                  Width="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch"
                                  Background="#DCE3EC"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="True" />

                    <Border Grid.Column="2" BorderBrush="#DCE3EC" BorderThickness="1" CornerRadius="8" Padding="14">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding SelectedProject.Name, StringFormat={}NuGet updates: {0}}"
                                           Style="{StaticResource PanelTitle}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding PackageUpdates.Count, StringFormat={}{0} package(s)}"
                                           Foreground="#607086" />
                            </Grid>

                            <DataGrid ItemsSource="{Binding PackageUpdates}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      SelectionMode="Extended">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Use" Width="56">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEnabled="{Binding CanApply}"
                                                          HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Project"
                                                        Binding="{Binding ProjectName}"
                                                        IsReadOnly="True"
                                                        Width="1.1*" />
                                    <DataGridTextColumn Header="Package"
                                                        Binding="{Binding PackageName}"
                                                        IsReadOnly="True"
                                                        Width="2*" />
                                    <DataGridTextColumn Header="Current"
                                                        Binding="{Binding CurrentVersion}"
                                                        IsReadOnly="True"
                                                        Width="120" />
                                    <DataGridTextColumn Header="Latest"
                                                        Binding="{Binding LatestVersion}"
                                                        IsReadOnly="True"
                                                        Width="120" />
                                    <DataGridTemplateColumn Header="Target" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding AvailableVersions}"
                                                          SelectedItem="{Binding TargetVersion, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEnabled="{Binding CanApply}"
                                                          MinWidth="118" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="Check updates"
                            Command="{Binding CheckUpdatesCommand}" />
                    <TextBlock Grid.Column="1"
                               Text="Check package versions"
                               Style="{StaticResource PanelTitle}"
                               Margin="0,0,16,0" />
                    <Button Grid.Column="3"
                            Content="Package targets..."
                            Click="PackageTargets_Click" />
                    <Button Grid.Column="5"
                            Content="Use all"
                            Command="{Binding SelectAllPackageUpdatesCommand}" />
                    <Button Grid.Column="6"
                            Content="Clear use"
                            Command="{Binding ClearAllPackageUpdatesCommand}"
                            Margin="0" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#DCE3EC" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Solution update"
                               Style="{StaticResource PanelTitle}" />
                    <Button Grid.Column="1"
                            Content="Apply versions"
                            Command="{Binding ApplyUpdatesCommand}" />
                    <Button Grid.Column="2"
                            Content="Build"
                            Command="{Binding BuildCommand}" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#DCE3EC" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Project versions"
                               Style="{StaticResource PanelTitle}" />
                    <TextBlock Grid.Column="1"
                               Text="Version"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="2"
                             Text="{Binding NewVersion, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             VerticalContentAlignment="Center" />
                    <Button Grid.Column="3"
                            Content="Set version"
                            Command="{Binding SetSolutionVersionCommand}"
                            Margin="8,0,0,0" />
                </Grid>
            </Border>
            </Grid>

            <Border Grid.Row="2" Background="White" BorderBrush="#DCE3EC" BorderThickness="1" CornerRadius="8" Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="180" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Git release"
                               Style="{StaticResource PanelTitle}" />
                    <TextBlock Grid.Column="1"
                               Text="Commit message"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="2"
                             Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             VerticalContentAlignment="Center" />
                    <Button Grid.Column="3"
                            Content="Commit"
                            Command="{Binding CommitCommand}"
                            Margin="8,0,0,0" />
                    <TextBlock Grid.Column="5"
                               Text="Tag"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="6"
                             Text="{Binding TagPattern, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             VerticalContentAlignment="Center" />
                    <TextBlock Grid.Column="7"
                               Text="{Binding ResolvedTagName}"
                               Foreground="#607086"
                               Margin="8,0,12,0"
                               MaxWidth="120"
                               TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="8"
                            Content="Create tag"
                            Command="{Binding CreateTagCommand}"
                            Margin="0" />
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="0"
                      Grid.RowSpan="3"
                      Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      ShowsPreview="True" />

        <Border Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="2"
                Background="White"
                BorderBrush="#DCE3EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Workflow log"
                               Style="{StaticResource PanelTitle}" />

                    <ProgressBar Grid.Column="1"
                                 Width="140"
                                 Height="12"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="{Binding IsBusy}" />
                </Grid>

                <Border Grid.Row="2"
                        Background="#F8FAFC"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="8">
                    <TextBox Text="{Binding WorkflowLog, Mode=OneWay}"
                             TextChanged="WorkflowLog_TextChanged"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#3C4656"
                             FontFamily="Consolas"
                             FontSize="12"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalContentAlignment="Top"
                             HorizontalContentAlignment="Left"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
